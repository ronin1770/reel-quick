# Copy repo sample.env values here as needed.
# These defaults are safe for container-to-container networking.
MONGODB_URI=mongodb://mongo:27017
REDIS_URL=redis://redis:6379/1
OUTPUT_FILES_LOCATION=/app/outputs
UPLOAD_FILES_LOCATION=/app/video_files
INPUT_FILES_LOCATION=/app/video_files
LOG_LOCATION=/app/logs/reel_quick.log
